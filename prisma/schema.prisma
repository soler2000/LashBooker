generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  STAFF
  ADMIN
  OWNER
}

enum DepositType {
  NONE
  FIXED
  PERCENT
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  COMPLETED
  CANCELLED_BY_CLIENT
  CANCELLED_BY_ADMIN
  NO_SHOW
}

enum PaymentProvider {
  STRIPE
}

enum PaymentStatus {
  REQUIRES_PAYMENT_METHOD
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum CampaignSegmentType {
  LAPSED
  VIP
  INFILL_DUE
}

enum CampaignStatus {
  DRAFT
  SENDING
  SENT
}

enum CampaignRecipientStatus {
  QUEUED
  SENT
  FAILED
  OPENED
  CLICKED
  UNSUBSCRIBED
}

enum TransactionalEmailLogStatus {
  QUEUED
  SENT
  FAILED
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  passwordHash           String?
  mustChangePassword     Boolean                 @default(false)
  role                   Role                    @default(CLIENT)
  lastLoginAt            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  clientProfile          ClientProfile?
  bookings               Booking[]
  clientJournalEntries   JournalEntry[]          @relation("ClientJournalEntries")
  authoredJournalEntries JournalEntry[]          @relation("AuthoredJournalEntries")
  accounts               Account[]
  sessions               Session[]
  campaignRecipients     CampaignRecipient[]
  transactionalEmailLogs TransactionalEmailLog[]
  visitorSessions        VisitorSession[]
}

model VisitorSession {
  id           String      @id @default(cuid())
  visitorKey   String
  startedAt    DateTime    @default(now())
  lastSeenAt   DateTime    @default(now())
  isNewVisitor Boolean     @default(true)
  country      String?
  region       String?
  city         String?
  userAgent    String?
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  pageVisits   PageVisit[]

  @@index([visitorKey])
  @@index([startedAt])
  @@index([lastSeenAt])
  @@index([country])
}

model PageVisit {
  id               String         @id @default(cuid())
  visitorSessionId String
  path             String
  referrer         String?
  visitedAt        DateTime       @default(now())
  durationSeconds  Int?
  visitorSession   VisitorSession @relation(fields: [visitorSessionId], references: [id], onDelete: Cascade)

  @@index([visitedAt])
  @@index([path])
  @@index([visitorSessionId])
  @@index([visitedAt, path])
}

model ClientProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  firstName         String
  lastName          String
  phone             String?
  marketingConsent  Boolean   @default(false)
  notes             String?
  contraindications String?
  patchTestAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id                  String      @id @default(uuid())
  name                String      @unique
  description         String
  durationMinutes     Int
  priceCents          Int
  depositType         DepositType
  depositValue        Int
  bufferBeforeMinutes Int         @default(0)
  bufferAfterMinutes  Int         @default(0)
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  bookings            Booking[]
}

model Booking {
  id                         String                  @id @default(uuid())
  clientId                   String
  serviceId                  String
  serviceName                String
  serviceDurationMinutes     Int
  servicePriceCents          Int
  serviceDepositType         DepositType
  serviceDepositValue        Int
  serviceBufferBeforeMinutes Int
  serviceBufferAfterMinutes  Int
  startAt                    DateTime
  endAt                      DateTime
  status                     BookingStatus           @default(PENDING_PAYMENT)
  policyAcceptedAt           DateTime
  notes                      String?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  client                     User                    @relation(fields: [clientId], references: [id])
  service                    Service                 @relation(fields: [serviceId], references: [id])
  payments                   Payment[]
  journalEntries             JournalEntry[]
  transactionalEmailLogs     TransactionalEmailLog[]
}

model JournalEntry {
  id          String         @id @default(uuid())
  clientId    String
  bookingId   String
  createdById String
  notes       String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  client      User           @relation("ClientJournalEntries", fields: [clientId], references: [id], onDelete: Cascade)
  booking     Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("AuthoredJournalEntries", fields: [createdById], references: [id], onDelete: Cascade)
  images      JournalImage[]
}

model JournalImage {
  id             String       @id @default(uuid())
  journalEntryId String
  objectKey      String       @unique
  mimeType       String
  createdAt      DateTime     @default(now())
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
}

model Payment {
  id                      String          @id @default(uuid())
  bookingId               String
  provider                PaymentProvider
  providerPaymentIntentId String          @unique
  amountCents             Int
  currency                String
  status                  PaymentStatus
  capturedAt              DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  booking                 Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model BusinessSettings {
  id                          String      @id @default("default")
  businessName                String
  timezone                    String
  currency                    String
  depositDefaultType          DepositType
  depositDefaultValue         Int
  mailProviderType            String?
  smtpHost                    String?
  smtpPort                    Int?
  smtpUsername                String?
  smtpPasswordEncrypted       String?
  smtpSecretRef               String?
  mailFromName                String?
  mailFromEmail               String?
  mailReplyTo                 String?
  smtpUseTls                  Boolean?
  smtpUseStarttls             Boolean?
  rescheduleCutoffHours       Int         @default(24)
  cancelCutoffHours           Int         @default(24)
  pendingPaymentExpiryMinutes Int         @default(30)
  instagramUrl                String?
  contactPhone                String?
  contactEmail                String?
  addressLine1                String?
  addressLine2                String?
  addressCity                 String?
  addressPostcode             String?
  addressCountry              String?
  reminderScheduleJson        String
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt
}

model TransactionalEmailTemplate {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  subject   String
  htmlBody  String
  textBody  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionalEmailLog {
  id                String                      @id @default(uuid())
  templateKey       String
  recipientEmail    String
  recipientUserId   String?
  bookingId         String?
  dedupeKey         String?
  status            TransactionalEmailLogStatus @default(QUEUED)
  providerMessageId String?
  error             String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  recipientUser     User?                       @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)
  booking           Booking?                    @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([dedupeKey, status])
  @@index([createdAt])
}

model WorkingHours {
  id        String  @id @default(uuid())
  weekday   Int     @unique
  startTime String
  endTime   String
  isClosed  Boolean @default(false)
}

model Blockout {
  id        String   @id @default(uuid())
  startAt   DateTime
  endAt     DateTime
  reason    String
  createdAt DateTime @default(now())
}

model Campaign {
  id          String              @id @default(uuid())
  name        String
  subject     String
  bodyHtml    String
  bodyText    String?
  segmentType CampaignSegmentType
  status      CampaignStatus      @default(DRAFT)
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  recipients  CampaignRecipient[]

  @@index([createdAt])
}

model CampaignRecipient {
  id                String                  @id @default(uuid())
  campaignId        String
  clientId          String
  email             String
  status            CampaignRecipientStatus @default(QUEUED)
  providerMessageId String?
  failureReason     String?
  queuedAt          DateTime                @default(now())
  sentAt            DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  unsubscribedAt    DateTime?
  updatedAt         DateTime                @updatedAt
  campaign          Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  client            User                    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([campaignId, clientId])
  @@index([campaignId, status])
  @@index([providerMessageId])
}

model Consumable {
  id           String   @id @default(uuid())
  name         String   @unique
  unit         String?
  targetStock  Int
  currentStock Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
